# ─────────────────────────────────────────────────────────────
# prompt-autotuner — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# All options here can also be set in ~/.autotuner/config.yaml.
# Priority: .env (process.env) → ~/.autotuner/config.yaml → defaults
# ─────────────────────────────────────────────────────────────

# [REQUIRED] OpenRouter API key — used by the Express server to proxy LLM calls.
# Get one at https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-...

# [OPTIONAL] Static/proxy server port (default: 3000)
# If explicitly set and occupied → error. If omitted and default occupied → auto-finds free port.
# PORT=3000

# [OPTIONAL] Express API server port (default: 3001)
# Same explicit/default behavior as PORT.
# API_PORT=3001

# [OPTIONAL] Data directory (default: ~/.autotuner)
# AUTOTUNER_DIR=~/.autotuner

# [OPTIONAL] Saved prompts storage backend (default: file)
#   file         — $AUTOTUNER_DIR/saved-prompts/{id}.yaml (recommended)
#   localstorage — browser localStorage only
# STORAGE_BACKEND=file
