{
  "name": "prompt-autotuner",
  "version": "0.1.1",
  "type": "module",
  "bin": {
    "autotuner": "bin/autotuner.js"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node bin/autotuner.js"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.2"
  }
}
