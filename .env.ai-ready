# ─────────────────────────────────────────────────────────────
# prompt-autotuner — AI Agent Ready Environment
# ─────────────────────────────────────────────────────────────
# Ready-to-use .env for AI agentic coding sessions.
# The only required secret is OPENROUTER_API_KEY.
# Set it in your AI agent's secrets/environment variables.
#
# All options here can also be set in ~/.autotuner/config.yaml.
# Priority: .env (process.env) → ~/.autotuner/config.yaml → defaults
# ─────────────────────────────────────────────────────────────

# [REQUIRED] Set this in your agent's secrets manager.
# OPENROUTER_API_KEY=sk-or-...

# Dev server ports (defaults work out of the box — do not uncomment unless you understand the mapping)
# PORT=3001        # Express API server (read by server/index.ts)
# API_PORT=3001    # CLI only (read by bin/autotuner.js)

# Saved prompts storage backend (file = ~/.autotuner/saved-prompts/{id}.yaml)
# STORAGE_BACKEND=file
